# Supabase project URL used by server-side Netlify Functions.
SUPABASE_URL=

# Server-side Supabase secret key for Netlify Functions only.
# Do not expose this value in browser/client code and do not prefix it with VITE_.
SUPABASE_SECRET_KEY=

# SHA-256 hash of the shared admin PIN. Example generator:
# printf %s "1234" | shasum -a 256 | awk '{print $1}'
ADMIN_PIN_HASH=

# Long random secret used to sign short-lived admin bearer tokens.
ADMIN_SESSION_SECRET=
